# Скопируйте в .env в корне репозитория и подставьте свои значения.
# cp compose.env.example .env

POSTGRES_USER=cda
POSTGRES_PASSWORD=cda_change_me
POSTGRES_DB=cda

# Порт HTTP на хосте (прод: docker-compose.server.yml)
HTTP_PORT=80
# HTTPS (после выпуска сертификата Let’s Encrypt, см. scripts/letsencrypt-ip-setup.sh)
HTTPS_PORT=443

# Локально с HMR (docker-compose.local.yml): порт Vite на машине → контейнер :3000
DEV_PORT=3000

# Сборка Vite (docker build nginx): два бандла — основной (/) и new-demo (/new-demo/).
# Основной стенд (main + demo):
VITE_GROQ_API_KEY=
VITE_EXPO=
# Через запятую id вкладок (латиница, нижний регистр): face, scenarios, planning, ontology, results, admin
# Чтобы отключить «Планирование», обязательно включите planning в список, например:
# VITE_EXPO_DISABLE_TABS=scenarios,planning,ontology,results,admin
# GitHub Actions: секреты VITE_* для основного стенда; NEW_DEMO_VITE_* — для /new-demo/ (если не заданы, CI подставит значения основных).
# и docker compose подхватывает его после .env, чтобы пустые строки в .env не затирали секреты.
VITE_EXPO_DISABLE_TABS=
VITE_EXPO_ARM_DELAY_MS=
VITE_EXPO_IDLE_MS=
# Отдельно для стенда new-demo (опционально; иначе compose возьмёт те же значения, что и VITE_* выше):
NEW_DEMO_VITE_GROQ_API_KEY=
NEW_DEMO_VITE_EXPO=
NEW_DEMO_VITE_EXPO_DISABLE_TABS=
NEW_DEMO_VITE_EXPO_ARM_DELAY_MS=
NEW_DEMO_VITE_EXPO_IDLE_MS=
