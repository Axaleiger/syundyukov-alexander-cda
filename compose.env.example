# Скопируйте в .env рядом с docker-compose.yml и подставьте свои значения.
# cp compose.env.example .env

POSTGRES_USER=cda
POSTGRES_PASSWORD=cda_change_me
POSTGRES_DB=cda

# Порт HTTP на хосте (прод: nginx в docker-compose.yml + docker-compose.server.yml)
HTTP_PORT=80

# Локально с HMR (docker-compose.local.yml): порт Vite на машине → контейнер :3000
DEV_PORT=3000

# Сборка Vite (docker build web); значение из корня workspace _env при локальном деплое
VITE_GROQ_API_KEY=
